# OpenClaw Dashboard — Environment Variables
# Copy to .env.local and fill in values as needed.

# ── OpenClaw Session ──────────────────────────────────────────────
# Controller session ID (overrides pipeline-config.json)
# OPENCLAW_SESSION_ID=

# ── Project Resolution ────────────────────────────────────────────
# Active project ID (overrides config/active-project.json and auto-detect)
# OPENCLAW_PROJECT=ordertu-qa

# ── Gateway (optional — only needed if not using ~/.openclaw/openclaw.json) ──
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_GATEWAY_TOKEN=

# ── Test Plans (optional) ────────────────────────────────────────
# TEST_PLANS_DIR=

# ── Docker / RuVector ────────────────────────────────────────────
# RuVector PostgreSQL database
RUVECTOR_DB_USER=ruvector
RUVECTOR_DB_PASSWORD=ruvector_secret
RUVECTOR_DB_NAME=openclaw_vectors
RUVECTOR_DB_PORT=5433
RUVECTOR_DIMENSIONS=384

# RuVector standalone server
RUVECTOR_SERVER_PORT=8080

# pgAdmin web UI
PGADMIN_EMAIL=admin@openclaw.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Workspace (optional) ────────────────────────────────────────
# OPENCLAW_WORKSPACE=~/.openclaw/workspace/qa-dashboard
