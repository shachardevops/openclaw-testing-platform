# OpenClaw Dashboard — Environment Variables
# Copy to .env.local and fill in values as needed.

# ── OpenClaw Session ──────────────────────────────────────────────
# Controller session ID (overrides pipeline-config.json)
# OPENCLAW_SESSION_ID=

# ── Project Resolution ────────────────────────────────────────────
# Active project ID (overrides config/active-project.json and auto-detect)
# OPENCLAW_PROJECT=ordertu-qa

# ── Gateway (optional — only needed if not using ~/.openclaw/openclaw.json) ──
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_GATEWAY_TOKEN=

# ── Direct AI SDKs (optional — reads from ~/.openclaw/openclaw.json by default) ──
# Override if you want to use different keys than what OpenClaw has configured.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DIRECT_AI_CLAUDE_MODEL=claude-sonnet-4-6
# DIRECT_AI_CODEX_MODEL=gpt-4.1

# ── Test Plans (optional) ────────────────────────────────────────
# TEST_PLANS_DIR=

# ── Docker / RuVector ────────────────────────────────────────────
# DEVELOPMENT ONLY — change all passwords/credentials in production
RUVECTOR_DB_USER=ruvector
RUVECTOR_DB_PASSWORD=ruvector_secret
RUVECTOR_DB_NAME=openclaw_vectors
RUVECTOR_DB_PORT=5433
RUVECTOR_DIMENSIONS=384

# RuVector standalone server
RUVECTOR_SERVER_PORT=8080

# DEVELOPMENT ONLY — change credentials in production
PGADMIN_EMAIL=admin@openclaw.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# DEVELOPMENT ONLY — change credentials in production
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3001

# ── Workspace (optional) ────────────────────────────────────────
# NOTE: This is documentation-only. The workspace path is resolved from
# config/<project>/project.json "workspace" field, not from this env var.
# OPENCLAW_WORKSPACE=~/.openclaw/workspace/qa-dashboard
